// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Categories {
  id         Int       @id @default(autoincrement())
  created_at DateTime  @default(now())
  updated_at DateTime?
  created_by Int?
  updated_by Int?

  slug        String
  icon        String
  title       String
  description String
  code        String @unique

  @@map("categories")
}

model Tags {
  id         Int       @id @default(autoincrement())
  created_at DateTime  @default(now())
  updated_at DateTime?
  created_by Int?
  updated_by Int?

  slug String
  code String @unique

  @@map("tags")
}

model Article {
  id         Int       @id @default(autoincrement())
  created_at DateTime  @default(now())
  updated_at DateTime?
  created_by Int?
  updated_by Int?

  slug            String
  title           String
  title_vi        String
  description     String
  description_vi  String
  content         String
  content_vi      String
  category_id     Int
  tags            Json
  readingTime     Float
  author          String
  toc             Json
  related_article Json

  @@map("article")
}
